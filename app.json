{
  "expo": {
    "name": "GarageJam",
    "slug": "garage-jam-app",
    "owner": "cajuuh1337",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "garagejam",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cajuuh.garagejam",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "GarageJam needs access to your microphone to record and play back audio jams.",
        "UIBackgroundModes": [
          "audio",
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "package": "com.cajuuh.garagejam"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-audio",
      [
        "expo-build-properties",
        {
          "android": {
            "memoryMaximumSize": "4096m",
            "usesCleartextTraffic": true,
            "gradleVersion": "8.7",
            "kotlinVersion": "2.1.20",
            "compileSdkVersion": 36,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          },
          "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.cajuuh.garagejam",
            "infoPlist": {
              "NSMicrophoneUsageDescription": "GarageJam needs access to your microphone to record and play back audio jams.",
              "UIBackgroundModes": [
                "audio"
              ]
            }
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "63aeb5ab-5e20-4538-92ff-dc9848015ddd"
      }
    }
  }
}
